APP_NAME=Net-Zero AI Server
ENVIRONMENT=local

# Redis is optional. If omitted or unavailable, the app uses an in-memory cache.
REDIS_URL=redis://localhost:6379/0

# LLM explanation layer uses AWS Bedrock Llama API.
LLM_PROVIDER=bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=meta.llama3-2-1b-instruct-v1:0

# Local vector cache database.
VECTOR_DB_PATH=.cache/vector_cache.sqlite3
SEMANTIC_CACHE_THRESHOLD=0.92
