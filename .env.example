APP_NAME=Net-Zero AI Server
ENVIRONMENT=local

# DATA_SOURCE only affects legacy demo endpoints:
# /forecast, /order-recommendation, /daily-close, /chat.
# Spring /v1 endpoints receive backend presigned S3 URLs and do not need S3 credentials.
# DATA_SOURCE=local reads app/data/*.csv.
# DATA_SOURCE=s3 directly reads the three CSV files below from S3.
DATA_SOURCE=local
S3_BUCKET=
S3_PREFIX=
S3_INVENTORY_FLOW_KEY=inventory_flow_5y.csv
S3_ITEM_MASTER_KEY=item_master.csv
S3_ORDER_POLICY_KEY=order_policy.csv
STORE_ID=inha-store-001

# Redis is optional. If omitted or unavailable, the app uses an in-memory cache.
# Use a managed or self-hosted Redis endpoint here.
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# LLM explanation layer uses local Llama 3.2 1B.
LLM_PROVIDER=local
LOCAL_LLM_BACKEND=ollama
LOCAL_LLM_MODEL=llama3.2:1b
LOCAL_HF_MODEL=meta-llama/Llama-3.2-1B-Instruct
LOCAL_GGUF_MODEL_PATH=
OLLAMA_BASE_URL=http://localhost:11434

# AWS is only needed for direct S3 loading. Spring /v1 presigned URLs do not need AWS credentials.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Alternative: use a local AWS profile instead of direct keys.
# AWS_PROFILE=default

# Local vector cache database.
VECTOR_DB_PATH=.cache/vector_cache.sqlite3
SEMANTIC_CACHE_THRESHOLD=0.92
