APP_NAME=Net-Zero AI Server
ENVIRONMENT=local

# DATA_SOURCE only affects legacy demo endpoints:
# /forecast, /order-recommendation, /daily-close, /chat.
# Spring /v1 endpoints receive backend presigned S3 URLs and do not need S3 credentials.
# DATA_SOURCE=local reads app/data/*.csv.
# DATA_SOURCE=s3 directly reads the three CSV files below from S3.
DATA_SOURCE=local
S3_BUCKET=
S3_PREFIX=
S3_INVENTORY_FLOW_KEY=inventory_flow_5days.csv
S3_ITEM_MASTER_KEY=item_master.csv
S3_ORDER_POLICY_KEY=order_policy.csv
STORE_ID=inha-store-001

# Redis is optional. If omitted or unavailable, the app uses an in-memory cache.
# For AWS ElastiCache Redis, set this to the primary endpoint, for example:
# REDIS_URL=redis://my-cache.xxxxxx.ng.0001.apn2.cache.amazonaws.com:6379/0
REDIS_URL=redis://localhost:6379/0

# Optional CloudWatch lookup for AWS/ElastiCache cache metrics.
# Set one of these IDs if you want /cache-status to include AWS metrics.
ELASTICACHE_REPLICATION_GROUP_ID=
ELASTICACHE_CACHE_CLUSTER_ID=
AWS_METRICS_WINDOW_MINUTES=5

# LLM explanation layer uses AWS Bedrock Llama API.
# Actual Bedrock calls require AWS credentials and model access.
# Prefer AWS_PROFILE or an IAM role. Do not commit real access keys.
# AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
LLM_PROVIDER=bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=meta.llama3-2-1b-instruct-v1:0

# Local vector cache database.
VECTOR_DB_PATH=.cache/vector_cache.sqlite3
SEMANTIC_CACHE_THRESHOLD=0.92
